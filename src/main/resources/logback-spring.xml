<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 彩色日志格式：Logback 原生颜色转换器 -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %magenta([%t]) %cyan(%-40.40logger{39}) : %m%n%ex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 项目包 DEBUG，能看到所有日志 -->
    <logger name="com.xiaohua.echo" level="DEBUG"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
